    "test.watch": "stencil test --spec --e2e --watchAll"
  },
  "devDependencies": {
    "@stencil/core": "1.1.3",
    "@types/jest": "^24.0.15",
    "@types/mapbox-gl": "^0.51.12"
  },
  "license": "MIT",
  "dependencies": {
    "ag-grid-community": "^21.1.0",
    "leaflet": "^1.5.1",
    "mapbox-gl": "^1.1.1",
    "sortablejs": "^1.10.0-rc3"
  }
}
